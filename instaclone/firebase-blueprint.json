{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "description": "User's profile photo URL." },
        "email": { "type": "string", "description": "User's email address." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Post": {
      "title": "Post",
      "description": "A social media post with a photo.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique post ID." },
        "authorId": { "type": "string", "description": "UID of the post author." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "authorPhoto": { "type": "string", "description": "Profile photo of the author." },
        "imageUrl": { "type": "string", "description": "URL of the posted image." },
        "caption": { "type": "string", "description": "Post caption." },
        "likesCount": { "type": "number", "description": "Number of likes." },
        "commentsCount": { "type": "number", "description": "Number of comments." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["authorId", "imageUrl", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who liked." },
        "postId": { "type": "string", "description": "ID of the liked post." }
      },
      "required": ["userId", "postId"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique comment ID." },
        "postId": { "type": "string", "description": "ID of the post." },
        "authorId": { "type": "string", "description": "UID of the comment author." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "authorPhoto": { "type": "string", "description": "Profile photo of the author." },
        "text": { "type": "string", "description": "Comment text." },
        "parentId": { "type": "string", "description": "ID of the parent comment (for nested replies)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["postId", "authorId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique notification ID." },
        "recipientId": { "type": "string", "description": "UID of the user receiving the notification." },
        "senderId": { "type": "string", "description": "UID of the user who triggered the notification." },
        "senderName": { "type": "string", "description": "Name of the user who triggered the notification." },
        "senderPhoto": { "type": "string", "description": "Photo of the user who triggered the notification." },
        "type": { "type": "string", "enum": ["like", "comment"], "description": "Type of notification." },
        "postId": { "type": "string", "description": "ID of the related post." },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["recipientId", "senderId", "type", "postId", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles." },
    "/posts/{postId}": { "schema": "Post", "description": "Social media posts." },
    "/posts/{postId}/likes/{likeId}": { "schema": "Like", "description": "Likes on a post." },
    "/posts/{postId}/comments/{commentId}": { "schema": "Comment", "description": "Comments on a post." },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications." }
  }
}
